    budget.responsibility_code,
    budget.project_leader,

    /* ========================= TOTAL ALLOTMENT ========================= */
    (
        COALESCE((SELECT SUM(dps.approved_budget)
                  FROM tbl_budget_direct_ps_dt dps
                  JOIN tbl_budget_hd hd ON dps.project_id = hd.recid
                  WHERE hd.project_title = budget.project_title),0)
        + COALESCE((SELECT SUM(idps.approved_budget)
                  FROM tbl_budget_indirect_ps_dt idps
                  JOIN tbl_budget_hd hd ON idps.project_id = hd.recid
                  WHERE hd.project_title = budget.project_title),0)
        + COALESCE((SELECT SUM(dmooe.approved_budget)
                  FROM tbl_budget_direct_mooe_dt dmooe
                  JOIN tbl_budget_hd hd ON dmooe.project_id = hd.recid
                  WHERE hd.project_title = budget.project_title),0)
        + COALESCE((SELECT SUM(idmooe.approved_budget)
                  FROM tbl_budget_indirect_mooe_dt idmooe
                  JOIN tbl_budget_hd hd ON idmooe.project_id = hd.recid
                  WHERE hd.project_title = budget.project_title),0)
        + COALESCE((SELECT SUM(dco.approved_budget)
                  FROM tbl_budget_direct_co_dt dco
                  JOIN tbl_budget_hd hd ON dco.project_id = hd.recid
                  WHERE hd.project_title = budget.project_title),0)
        + COALESCE((SELECT SUM(idco.approved_budget)
                  FROM tbl_budget_indirect_co_dt idco
                  JOIN tbl_budget_hd hd ON idco.project_id = hd.recid
                  WHERE hd.project_title = budget.project_title),0)
    ) AS allotment,

    /* ========================= ADMIN COST ========================= */
    COALESCE((SELECT SUM(approved_budget)
              FROM tbl_budget_savings_dt
              WHERE project_id = budget.recid),0) AS admin_cost,

    /* ========================= REVISED ========================= */
    (
        (
            COALESCE((SELECT SUM(dps.approved_budget) FROM tbl_budget_direct_ps_dt dps
                      JOIN tbl_budget_hd hd ON dps.project_id = hd.recid
                      WHERE hd.project_title = budget.project_title),0)
            + COALESCE((SELECT SUM(idps.approved_budget) FROM tbl_budget_indirect_ps_dt idps
                      JOIN tbl_budget_hd hd ON idps.project_id = hd.recid
                      WHERE hd.project_title = budget.project_title),0)
            + COALESCE((SELECT SUM(dmooe.approved_budget) FROM tbl_budget_direct_mooe_dt dmooe
                      JOIN tbl_budget_hd hd ON dmooe.project_id = hd.recid
                      WHERE hd.project_title = budget.project_title),0)
            + COALESCE((SELECT SUM(idmooe.approved_budget) FROM tbl_budget_indirect_mooe_dt idmooe
                      JOIN tbl_budget_hd hd ON idmooe.project_id = hd.recid
                      WHERE hd.project_title = budget.project_title),0)
            + COALESCE((SELECT SUM(dco.approved_budget) FROM tbl_budget_direct_co_dt dco
                      JOIN tbl_budget_hd hd ON dco.project_id = hd.recid
                      WHERE hd.project_title = budget.project_title),0)
            + COALESCE((SELECT SUM(idco.approved_budget) FROM tbl_budget_indirect_co_dt idco
                      JOIN tbl_budget_hd hd ON idco.project_id = hd.recid
                      WHERE hd.project_title = budget.project_title),0)
        )
        - COALESCE((SELECT SUM(approved_budget)
                    FROM tbl_budget_savings_dt
                    WHERE project_id = budget.recid),0)
    ) AS revised_allotment,


    COALESCE((
            SELECT SUM(amount) 
            FROM tbl_ors_direct_mooe_dt d 
            JOIN
            tbl_ors_hd hd ON d.`project_id` = hd.`recid`
            WHERE d.sub_object_code = b.particulars AND d.`uacs_code` = b.`code` AND hd.`ors_date` >= \'2026-01-01\' AND hd.`ors_date` <= \'2026-01-31\' AND d.project_title = budget.project_title
        ), 0) + COALESCE((
            SELECT SUM(amount) 
            FROM tbl_ors_indirect_mooe_dt i 
            JOIN
            tbl_ors_hd hd ON i.`project_id` = hd.`recid`
            WHERE i.sub_object_code = b.particulars AND i.`uacs_code` = b.`code` AND hd.`ors_date` >= \'2026-01-01\' AND hd.`ors_date` <= \'2026-01-31\' AND i.project_title = budget.project_title
        ), 0) AS this_month,
   

    /* ========================= TO DATE (JAN–DEC 2025) ========================= */
    (
        COALESCE((SELECT SUM(dmooe.amount)
                  FROM tbl_ors_direct_mooe_dt dmooe
                  JOIN tbl_ors_hd hd ON dmooe.project_id = hd.recid
                  WHERE dmooe.project_title = budget.project_title
                  AND hd.ors_date BETWEEN \'2026-01-01\' AND \'2026-01-31\'),0)
        +
        COALESCE((SELECT SUM(idmooe.amount)
                  FROM tbl_ors_indirect_mooe_dt idmooe
                  JOIN tbl_ors_hd hd ON idmooe.project_id = hd.recid
                  WHERE idmooe.project_title = budget.project_title
                  AND hd.ors_date BETWEEN \'2026-01-01\' AND \'2026-01-31\'),0)     
    ) AS todate


FROM tbl_budget_hd budget
WHERE budget.program_title = \'Scientific Research and Development Services on Basic and Applied Researches on Food and Nutrition\'
AND budget.duration_from <= \'2026-01-31\'
AND budget.duration_to   >= \'2026-01-01\'
ORDER BY 
    CASE 
        WHEN budget.responsibility_code = \'19-003-00-00000-2-2026\' THEN 0
        ELSE 1
    END,
    budget.responsibility_code ASC
')
