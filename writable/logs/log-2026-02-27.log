    ) AS todate


FROM tbl_budget_hd budget
WHERE budget.program_title = \'Expanding the FNRI\\\'s Nutrigenomics Laboratory: Towards Establishment of a World Class Philippines Nutrigenomics Center\'
AND budget.duration_from <= \'2026-01-31\'
AND budget.duration_to   >= \'2026-01-01\'

ORDER BY 
    CASE 
        /* Group 1: Admin/Support Units (FAD/MIS) */
        WHEN budget.responsibility_code LIKE \'%-3-4(FAD)-%\' THEN 0
        WHEN budget.responsibility_code LIKE \'%-3-4(MIS)-%\' THEN 1
        
        /* Group 2: The 2-3 series Manual sequencing */
        WHEN budget.responsibility_code LIKE \'%-00000-2-3-1-2026\' THEN 2
        WHEN budget.responsibility_code LIKE \'%-00000-2-3-2-2026\' THEN 3
        
        /* Moving these two AFTER 2-3-2 ONLY for the specific Nutrigenomics program */
        WHEN budget.responsibility_code LIKE \'%-00000-2-3-2026\' 
             AND budget.program_title = %Expanding the FNRI%
             THEN 4
             
        WHEN budget.responsibility_code LIKE \'%-00000-2-3-3-2026\' 
             AND budget.program_title LIKE %Expanding the FNRI%
             THEN 5
        
        /* Group 3: Other specific codes */
        WHEN budget.responsibility_code LIKE \'%-3-3-2026\' THEN 6
        WHEN budget.responsibility_code = \'19-003-00-00000-2-2026\' THEN 7
        ELSE 8
    END ASC,

    /* Secondary sort for the rest of the list */
    CAST(
        SUBSTRING_INDEX(
            SUBSTRING_INDEX(budget.responsibility_code, \'-\', -2),
        \'-\', 1
        ) AS UNSIGNED
    ) ASC,

    /* Tertiary sort: year */
    CAST(
        SUBSTRING_INDEX(budget.responsibility_code, \'-\', -1)
    AS UNSIGNED) ASC
 
')
